{
  "name": "embankment-www",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --outDir out-prod && scripts/generate-static-pages.sh out-prod && node scripts/inject-og-tags.cjs out-prod",
    "build-dev": "VITE_SITE_URL=https://dev.embankment.org vite build --outDir out-dev && scripts/generate-static-pages.sh out-dev && VITE_SITE_URL=https://dev.embankment.org node scripts/inject-og-tags.cjs out-dev",
    "preview": "vite preview",
    "b": "npm run build",
    "bd": "npm run build-dev",
    "nb": "npm run build",
    "nbd": "npm run build-dev",
    "deploy-dev": "rsync -avzh --delete --update out-dev/ epc:dev_html/",
    "dd": "rsync -avzh --delete --update out-dev/ epc:dev_html/",
    "ddn": "rsync -avzhn --delete --update out-dev/ epc:dev_html/",
    "dbd": "npm run bd && npm run dd",
    "deploy-main": "rsync -avzh --delete --update out-prod/ epc:public_html/",
    "dm": "rsync -avzh --delete --update out-prod/ epc:public_html/",
    "dmn": "rsync -avzhn --delete --update out-prod/ epc:public_html/"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/escape-html": "^1.0.1",
    "@types/luxon": "^3.0.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "dependencies": {
    "@rdub/base": "^0.8.1",
    "escape-html": "^1.0.3",
    "luxon": "^3.4.4",
    "moment": "^2.30.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.1.1",
    "react-scroll-parallax": "^3.5.0",
    "sass": "^1.66.1",
    "swiper": "^12.0.2",
    "yet-another-react-lightbox": "^3.25.0"
  }
}
