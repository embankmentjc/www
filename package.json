{
  "name": "embankment-www",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "scripts": {
    "webpack": "webpack --mode=development -w",
    "ssr": "node pages/server.js",
    "dev": "next dev",
    "b": "next build && scripts/restore-timestamps.sh .next-prod && rm -rf out-prod && mv .next-prod out-prod",
    "bd": "NEXT_PUBLIC_SITE_URL=https://dev.embankment.org next build && scripts/restore-timestamps.sh .next-dev && rm -rf out-dev && mv .next-dev out-dev",
    "build": "next build && scripts/restore-timestamps.sh .next-prod && rm -rf out-prod && mv .next-prod out-prod",
    "build-dev": "NEXT_PUBLIC_SITE_URL=https://dev.embankment.org next build && scripts/restore-timestamps.sh .next-dev && rm -rf out-dev && mv .next-dev out-dev",
    "export": "next build && scripts/restore-timestamps.sh .next-prod && write-redirects",
    "deploy-dev": "rsync -avzh --delete --update out-dev/ epc:dev_html/",
    "dd": "rsync -avzh --delete --update out-dev/ epc:dev_html/",
    "ddn": "rsync -avzhn --delete --update out-dev/ epc:dev_html/",
    "dbd": "npm run bd && npm run dd",
    "deploy-main": "rsync -avzh --delete --update out-prod/ epc:public_html/",
    "dm": "rsync -avzh --delete --update out-prod/ epc:public_html/",
    "dmn": "rsync -avzhn --delete --update out-prod/ epc:public_html/"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/escape-html": "^1.0.1",
    "@types/luxon": "^3.0.0",
    "@types/nodemailer": "^6.4.4",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.3.7",
    "ts-loader": "^9.2.7",
    "tsc": "^2.0.4",
    "typescript": "^4.6.2",
    "webpack": "^5.90.1",
    "webpack-cli": "^4.9.2",
    "write-redirects": "https://gitpkg.now.sh/runsascoded/next-write-redirects?18be2e3"
  },
  "dependencies": {
    "@mdx-js/react": "^2.1.5",
    "@rdub/base": "^0.8.1",
    "@rdub/next-base": "0.5.0",
    "escape-html": "^1.0.3",
    "luxon": "^3.4.4",
    "moment": "^2.29.1",
    "next": "^15.5.6",
    "nodemailer": "^6.9.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scroll-parallax": "^3.5.0",
    "sass": "^1.66.1",
    "swiper": "^12.0.2",
    "yet-another-react-lightbox": "^3.25.0"
  }
}
